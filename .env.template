# ─────────────────────────────────────────────────────────────────────────────
# UK Housing Affordability Intelligence API — Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Individual credentials used by the Docker Compose db service
POSTGRES_USER=housing_user
POSTGRES_PASSWORD=housing_pass
POSTGRES_DB=housing_db

# Full connection string used by SQLAlchemy / the API (must match credentials above)
DATABASE_URL=postgresql://housing_user:housing_pass@db:5432/housing_db

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-replace-with-a-random-32-char-string

# JWT signing algorithm — do not change
ALGORITHM=HS256

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Required only for the /insights endpoint.
# If unset, the endpoint returns a 503 with a clear message — the rest of the
# API functions normally without this key.
# Obtain from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Demo Credentials (Development Only) ───────────────────────────────────────
# Used to obtain a JWT token via POST /token
# Change these in any non-development environment
DEMO_USERNAME=admin
DEMO_PASSWORD=secret
